# Panel environment variables (copy to .env)

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/multiserverkit

# Panel web server
PORT=3000
PANEL_URL=https://panel.yourdomain.com

# Session / auth
SESSION_SECRET=change-me-to-a-long-random-secret

# Default API key used when registering new game servers (must match mod PanelApiKey)
# Each server can have its own key in the registry
