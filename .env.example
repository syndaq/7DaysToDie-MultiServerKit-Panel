# Public IP or hostname used to reach this machine from your browser
PUBLIC_HOST=YOUR-IP-HERE

# Database
DATABASE_URL=postgresql://msk:msk_dev_password@localhost:5432/multiserverkit

# Panel API (apps/api)
PORT=3001
HOST=0.0.0.0
# Comma-separated browser origins for CORS — use your machine's IP, not localhost
WEB_ORIGIN=http://YOUR-IP-HERE:5173

# Panel public URL (what you open in your browser)
PANEL_URL=http://YOUR-IP-HERE:5173
WEB_PORT=5173

# Session signing secret — use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-secret
# Set to true when serving the panel over HTTPS
COOKIE_SECURE=false

# --- Production Docker (docker-compose.prod.yml) ---
PANEL_PORT=80
POSTGRES_USER=msk
POSTGRES_PASSWORD=msk_prod_password
POSTGRES_DB=multiserverkit
